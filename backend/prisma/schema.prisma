generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int      @id @default(autoincrement())
  email             String   @unique
  password          String?
  firstName         String
  lastName          String
  phone             String?
  role              Role     @default(RIDER)
  profilePicture    String?
  isProfileBlurred  Boolean  @default(true)
  isActive          Boolean  @default(true)
  isSuspended       Boolean  @default(false)
  suspendedReason   String?
  rating            Float    @default(0)
  totalReviews      Int      @default(0)
  googleId          String?  @unique
  isGoogleUser      Boolean  @default(false)
  emailVerified     Boolean  @default(false)
  razorpayAccountId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  vehicles          Vehicle[]          @relation("DriverVehicles")
  ownedVehicles     Vehicle[]          @relation("OwnerVehicles")
  ridePools         RidePool[]
  tripsAsDriver     Trip[]              @relation("DriverTrips")
  tripsAsRider      Trip[]              @relation("RiderTrips")
  sentMessages      Message[]           @relation("SentMessages")
  receivedMessages  Message[]           @relation("ReceivedMessages")
  reviewsGiven      Review[]            @relation("ReviewsGiven")
  reviewsReceived   Review[]            @relation("ReviewsReceived")
  sosAlerts         SOSAlert[]
  rideRequests      RideRequest[]
  bookings          Booking[]
  payouts           Payout[]
  driverLocations   DriverLocation[]
  locationHistories LocationHistory[]
  payments          Payment[]
  wallet            Wallet?
  razorpayCustomer  RazorpayCustomer[]
  WalletTransaction WalletTransaction[]
  driverDocuments   DriverDocument[]    @relation("DriverDocuments")
  verifiedDriverDocs DriverDocument[]   @relation("VerifiedDriverDocs")
  verifiedVehicleDocs VehicleDocument[] @relation("VerifiedVehicleDocs")
  paymentMethods    PaymentMethod[]
  owner             Owner?
  ownerDocuments    OwnerDocument[]    @relation("OwnerDocuments")
  verifiedOwnerDocs OwnerDocument[]    @relation("VerifiedOwnerDocs")

  @@index([email])
  @@index([role])
  @@index([googleId])
}

model Vehicle {
  id                  Int               @id @default(autoincrement())
  driverId            Int
  ownerId             Int?
  brand               String
  make                String?
  model               String
  licensePlate        String            @unique
  color               String
  capacity            Int
  vehicleType         VehicleType       @default(SEDAN)
  verificationStatus  VerificationStatus @default(PENDING)
  preferences         Json              @default("{\"smoking\": false, \"pets\": false, \"music\": true}")
  isActive            Boolean           @default(true)
  registrationExpiry DateTime
  pricePerDay         Float             @default(0)
  pricePerKm          Float             @default(0)
  minimumCharge       Float             @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  driver    User       @relation(fields: [driverId], references: [id])
  owner     User?      @relation("OwnerVehicles", fields: [ownerId], references: [id])
  ridePools RidePool[]
  documents VehicleDocument[]

  @@index([driverId])
  @@index([ownerId])
  @@index([brand])
  @@index([verificationStatus])
}

model RidePool {
  id                Int        @id @default(autoincrement())
  driverId          Int
  vehicleId         Int
  pickupLocation    Json
  dropLocation      Json
  departureTime     DateTime
  availableSeats    Int
  pricePerSeat      Float
  status            RideStatus @default(ACTIVE)
  preferences       Json       @default("{\"smoking\": false, \"pets\": false, \"femaleOnly\": false, \"music\": true}")
  routeData         Json?
  distance          Float?
  estimatedDuration Int?
  bookedSeats       Int        @default(0)
  passengers        Json       @default("[]")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  driver       User          @relation(fields: [driverId], references: [id])
  vehicle      Vehicle       @relation(fields: [vehicleId], references: [id])
  trips        Trip[]
  messages     Message[]
  rideRequests RideRequest[]
  sosAlerts    SOSAlert[]
  bookings     Booking[]

  @@index([pickupLocation])
  @@index([dropLocation])
  @@index([departureTime])
  @@index([status])
  @@index([driverId])
  @@index([status, departureTime])
  @@index([status, driverId])
  @@index([driverId, status])
}

model Trip {
  id                Int        @id @default(autoincrement())
  ridePoolId        Int
  driverId          Int
  riderIds          Int[]
  startTime         DateTime?
  endTime           DateTime?
  status            TripStatus @default(SCHEDULED)
  totalFare         Float      @default(0)
  distance          Float?
  estimatedDuration Int?
  actualDistance    Float?
  actualDuration    Int?
  startLocation     Json?
  endLocation       Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  ridePool RidePool  @relation(fields: [ridePoolId], references: [id])
  driver   User      @relation("DriverTrips", fields: [driverId], references: [id])
  riders   User[]    @relation("RiderTrips")
  reviews  Review[]
  payouts  Payout[]
  payments Payment[]

  @@index([ridePoolId])
  @@index([driverId])
  @@index([status])
}

model Message {
  id              Int      @id @default(autoincrement())
  senderId        Int
  receiverId      Int
  ridePoolId      Int?
  content         String
  isRead          Boolean  @default(false)
  isSystemMessage Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sender   User      @relation("SentMessages", fields: [senderId], references: [id])
  receiver User      @relation("ReceivedMessages", fields: [receiverId], references: [id])
  ridePool RidePool? @relation(fields: [ridePoolId], references: [id])

  @@index([senderId, receiverId])
  @@index([createdAt])
}

model Review {
  id         Int        @id @default(autoincrement())
  tripId     Int
  reviewerId Int
  revieweeId Int
  type       ReviewType
  rating     Int
  comment    String?
  isVisible  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  trip     Trip @relation(fields: [tripId], references: [id])
  reviewer User @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee User @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@index([tripId])
  @@index([reviewerId])
  @@index([revieweeId])
}

model SOSAlert {
  id             Int       @id @default(autoincrement())
  userId         Int
  ridePoolId     Int?
  message        String?
  location       Json?
  status         SOSStatus @default(ACTIVE)
  acknowledgedBy Int?
  acknowledgedAt DateTime?
  resolvedAt     DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  ridePool RidePool? @relation(fields: [ridePoolId], references: [id])

  @@index([userId])
  @@index([ridePoolId])
  @@index([status])
  @@index([createdAt])
}

model RideRequest {
  id              Int           @id @default(autoincrement())
  ridePoolId      Int
  riderId         Int
  status          RequestStatus @default(PENDING)
  pickupLocation  Json?
  dropLocation    Json?
  requestedAt     DateTime      @default(now())
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  ridePool RidePool @relation(fields: [ridePoolId], references: [id])
  rider    User     @relation(fields: [riderId], references: [id])

  @@index([ridePoolId])
  @@index([riderId])
  @@index([status])
}

model SagaLog {
  id           Int        @id @default(autoincrement())
  sagaType     String
  status       SagaStatus @default(PENDING)
  currentStep  Int        @default(0)
  totalSteps   Int
  errorMessage String?
  context      Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  completedAt  DateTime?

  stepLogs SagaStepLog[]

  @@index([sagaType])
  @@index([status])
}

model SagaStepLog {
  id         Int      @id @default(autoincrement())
  sagaId     Int
  stepName   String
  status     String
  result     String?
  error      String?
  executedAt DateTime @default(now())

  saga SagaLog @relation(fields: [sagaId], references: [id])

  @@index([sagaId])
}

enum Role {
  DRIVER
  RIDER
  ADMIN
  OWNER
}

enum RideStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ReviewType {
  DRIVER_TO_RIDER
  RIDER_TO_DRIVER
}

enum SOSStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum SagaStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  COMPENSATING
  ROLLED_BACK
}

model Booking {
  id                  Int           @id @default(autoincrement())
  ridePoolId          Int
  riderId             Int
  rideRequestId       Int?
  seatsBooked         Int           @default(1)
  status              BookingStatus @default(PENDING)
  pickupLocation      Json?
  dropLocation        Json?
  startDate           DateTime?
  endDate             DateTime?
  totalAmount         Float         @default(0)
  paymentOrderId      String?
  razorpayPaymentId   String?
  confirmedAt         DateTime?
  cancelledAt         DateTime?
  cancelledBy         Int?
  cancellationReason   String?
  refundAmount        Float?
  refundStatus        RefundStatus?
  sagaState           SagaStatus?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  ridePool RidePool @relation(fields: [ridePoolId], references: [id])
  rider    User     @relation(fields: [riderId], references: [id])

  @@index([ridePoolId])
  @@index([riderId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([riderId, status])
  @@index([ridePoolId, riderId])
  @@index([status, createdAt])
}

enum BookingStatus {
  PENDING
  APPROVED
  PAID
  ACTIVE
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Payout {
  id               Int          @id @default(autoincrement())
  driverId         Int
  tripId           Int
  amount           Float
  platformFee      Float        @default(0)
  razorpayPayoutId String?
  status           PayoutStatus @default(PENDING)
  processedAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  driver User @relation(fields: [driverId], references: [id])
  trip   Trip @relation(fields: [tripId], references: [id])

  @@index([driverId])
  @@index([tripId])
  @@index([status])
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model Payment {
  id                Int           @id @default(autoincrement())
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?       @unique
  userId            Int?
  tripId            Int?
  vehicleId         Int?
  amount            Float
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  receipt           String?
  capturedAmount    Float?
  refundedAmount    Float?
  notes             Json?
  capturedAt        DateTime?
  refundedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user    User?    @relation(fields: [userId], references: [id])
  trip    Trip?    @relation(fields: [tripId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  refunds Refund[]

  @@index([razorpayOrderId])
  @@index([razorpayPaymentId])
  @@index([userId])
  @@index([vehicleId])
  @@index([status])
}

enum PaymentStatus {
  PENDING
  CAPTURED
  REFUNDED
  FAILED
}

model Refund {
  id                Int          @id @default(autoincrement())
  razorpayRefundId  String?      @unique
  razorpayPaymentId String?
  paymentId         Int
  amount            Float
  status            RefundStatus @default(PENDING)
  speed             String?
  notes             Json?
  processedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([razorpayRefundId])
  @@index([paymentId])
  @@index([status])
}

enum RefundStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Wallet {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  balance   Float    @default(0)
  currency  String   @default("INR")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]

  @@index([userId])
}

model WalletTransaction {
  id          Int             @id @default(autoincrement())
  walletId    Int
  userId      Int
  type        TransactionType
  amount      Float
  balance     Float
  reference   String?
  description String?
  createdAt   DateTime        @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([walletId])
  @@index([userId])
  @@index([type])
}

enum TransactionType {
  CREDIT
  DEBIT
}

model RazorpayCustomer {
  id         Int      @id @default(autoincrement())
  customerId String   @unique
  email      String
  name       String
  phone      String?
  userId     Int?     @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([email])
}

model DriverLocation {
  id        Int      @id @default(autoincrement())
  driverId  Int
  latitude  Float
  longitude Float
  heading   Float?
  speed     Float?
  accuracy  Float?
  timestamp DateTime @default(now())
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  driver User @relation(fields: [driverId], references: [id])

  @@index([driverId])
  @@index([timestamp])
  @@index([isActive])
  @@index([isActive, timestamp])
  @@index([driverId, timestamp])
}

model LocationHistory {
  id           Int          @id @default(autoincrement())
  driverId     Int
  latitude     Float
  longitude    Float
  heading      Float?
  speed        Float?
  accuracy     Float?
  locationType LocationType @default(DRIVER_LOCATION)
  relatedId    Int?
  timestamp    DateTime     @default(now())
  createdAt    DateTime     @default(now())

  driver User @relation("LocationHistories", fields: [driverId], references: [id])

  @@index([driverId])
  @@index([timestamp])
  @@index([locationType])
}

enum LocationType {
  DRIVER_LOCATION
  PICKUP_LOCATION
  DROPOFF_LOCATION
  SOS_LOCATION
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum DriverDocumentType {
  AADHAAR
  PAN
  PASSPORT_PHOTO
  DRIVING_LICENSE
  POLICE_VERIFICATION
  BANK_DETAILS
  BADGE
  MEDICAL_FITNESS
}

enum VehicleDocumentType {
  RC
  PERMIT
  INSURANCE
  FITNESS_CERTIFICATE
  PUC
  FASTAG
}

enum DocStatus {
  PENDING
  UPLOADED
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum VehicleType {
  SEDAN
  SUV
  HATCHBACK
  MINIVAN
  TEMPO
  MOTORCYCLE
  AUTO
  EV_SEDAN
  EV_SUV
  EV_HATCHBACK
  EV_AUTO
  EV_MOTORCYCLE
  LUXURY
  PREMIUM
  ECONOMY
  PICKUP
  TRUCK
  VAN
}

model DriverDocument {
  id             Int                  @id @default(autoincrement())
  driverId       Int
  documentType   DriverDocumentType
  url            String
  status         DocStatus            @default(PENDING)
  verifiedAt     DateTime?
  verifiedBy     Int?
  rejectedReason String?
  expiresAt      DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  driver       User @relation("DriverDocuments", fields: [driverId], references: [id])
  verifiedByUser User?                @relation("VerifiedDriverDocs", fields: [verifiedBy], references: [id])

  @@index([driverId])
  @@index([documentType])
  @@index([status])
  @@index([expiresAt])
}

model VehicleDocument {
  id             Int                   @id @default(autoincrement())
  vehicleId      Int
  documentType   VehicleDocumentType
  url            String
  status         DocStatus             @default(PENDING)
  verifiedAt     DateTime?
  verifiedBy     Int?
  rejectedReason String?
  expiresAt      DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  vehicle       Vehicle @relation(fields: [vehicleId], references: [id])
  verifiedByUser User?   @relation("VerifiedVehicleDocs", fields: [verifiedBy], references: [id])

  @@index([vehicleId])
  @@index([documentType])
  @@index([status])
  @@index([expiresAt])
}

model PaymentMethod {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  isDefault Boolean  @default(false)
  details   Json
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([status])
}

model Owner {
  id                 Int        @id @default(autoincrement())
  userId             Int        @unique
  businessName       String?
  gstNumber          String?
  panNumber          String?
  rejectionReason    String?
  verificationStatus DocStatus  @default(PENDING)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  user      User            @relation(fields: [userId], references: [id])
  documents OwnerDocument[]

  @@index([userId])
}

enum OwnerDocumentType {
  GST
  PAN
  BUSINESS_LICENSE
  ADDRESS_PROOF
}

model OwnerDocument {
  id             Int                @id @default(autoincrement())
  ownerId        Int
  documentType   OwnerDocumentType
  url            String
  status         DocStatus          @default(PENDING)
  verifiedAt     DateTime?
  verifiedBy     Int?
  rejectedReason String?
  expiresAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  owner         Owner    @relation(fields: [ownerId], references: [id])
  verifiedByUser User?   @relation("VerifiedOwnerDocs", fields: [verifiedBy], references: [id])

  @@index([ownerId])
  @@index([documentType])
  @@index([status])
  @@index([expiresAt])
}
