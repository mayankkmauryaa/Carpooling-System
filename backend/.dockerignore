.github
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# Documentation
docs
README.md
*.md

# Development
.env
.env.*
.env.local
.env.development
.env.test
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# Testing
tests
coverage
.nyc_output
*.test.js
*.spec.js

